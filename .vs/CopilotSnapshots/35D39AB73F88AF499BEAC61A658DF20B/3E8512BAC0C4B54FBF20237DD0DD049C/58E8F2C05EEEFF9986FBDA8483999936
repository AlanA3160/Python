#!/usr/bin/env python3
from dataclasses import dataclass, field
from enum import IntEnum
from typing import List
import datetime

class Priority(IntEnum):
    HIGH = 1
    MEDIUM = 2
    LOW = 3

    def label(self) -> str:
        return {Priority.HIGH: "High", Priority.MEDIUM: "Medium", Priority.LOW: "Low"}[self]

@dataclass(order=True)
class Task:
    sort_index: int = field(init=False, repr=False)
    priority: Priority
    name: str
    created_at: datetime.datetime = field(default_factory=datetime.datetime.now)

    def __post_init__(self):
        # Lower sort_index sorts first (High -> Low)
        self.sort_index = int(self.priority)

def prompt_priority() -> Priority:
    while True:
        raw = input("Priority (1=High, 2=Medium, 3=Low): ").strip()
        if raw in ("1", "2", "3"):
            return Priority(int(raw))
        # accept words
        lowered = raw.lower()
        if lowered in ("high", "h", "1"):
            return Priority.HIGH
        if lowered in ("medium", "m", "2"):
            return Priority.MEDIUM
        if lowered in ("low", "l", "3"):
            return Priority.LOW
        print("Invalid priority. Enter 1, 2, 3 or High/Medium/Low.")

def add_task(tasks: List[Task]) -> None:
    name = input("Task name: ").strip()
    if not name:
        print("Task name cannot be empty.")
        return
    pr = prompt_priority()
    tasks.append(Task(priority=pr, name=name))
    print(f"Added: '{name}' [{pr.label()}]")

def list_tasks(tasks: List[Task]) -> None:
    if not tasks:
        print("No tasks.")
        return
    # Sort by priority (1..3) then by creation time
    sorted_tasks = sorted(tasks, key=lambda t: (t.priority, t.created_at))
    print("\nTasks:")
    for i, t in enumerate(sorted_tasks, start=1):
        ts = t.created_at.strftime("%Y-%m-%d %H:%M:%S")
        print(f"{i}. [{t.priority.label()}] {t.name} (added: {ts})")
    print()

def what_is_next(tasks: List[Task]) -> None:
    """Show the oldest task that is Priority 1 (High).

    If there are no Priority 1 tasks, print an encouraging message.
    """
    # find all high priority tasks
    high_tasks = [t for t in tasks if t.priority == Priority.HIGH]
    if not high_tasks:
        print("No Priority 1 tasks. Nice work — consider adding a high priority task when needed.")
        return
    # oldest by creation time
    next_task = min(high_tasks, key=lambda t: t.created_at)
    ts = next_task.created_at.strftime("%Y-%m-%d %H:%M:%S")
    print(f"Next: [{next_task.priority.label()}] {next_task.name} (added: {ts})")

def complete_task(tasks: List[Task]) -> None:
    """Mark a task complete: remove from active list and append to history file."""
    if not tasks:
        print("No tasks to complete.")
        return
    # show numbered sorted tasks so user can pick by number
    sorted_tasks = sorted(tasks, key=lambda t: (t.priority, t.created_at))
    print("\nSelect a task to complete:")
    for i, t in enumerate(sorted_tasks, start=1):
        print(f"{i}. [{t.priority.label()}] {t.name}")
    raw = input("Enter task number (or cancel): ").strip()
    if not raw or raw.lower() in ("c", "x", "cancel"):
        print("Cancelled.")
        return
    if not raw.isdigit():
        print("Invalid selection.")
        return
    idx = int(raw)
    if idx < 1 or idx > len(sorted_tasks):
        print("Selection out of range.")
        return
    task = sorted_tasks[idx - 1]
    # remove the task object from the main list
    try:
        tasks.remove(task)
    except ValueError:
        # fallback: rebuild tasks without the selected task
        tasks[:] = [t for t in tasks if t is not task]

    # append to history file
    ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    entry = f"{ts} - [{task.priority.label()}] {task.name}\n"
    try:
        with open("completed_tasks.txt", "a", encoding="utf-8") as f:
            f.write(entry)
    except Exception as e:
        print(f"Warning: failed to write history file: {e}")
    print(f"Completed: '{task.name}'")

def main():
    tasks: List[Task] = []
    actions = {
        "add": add_task,
        "a": add_task,
        "list": list_tasks,
        "l": list_tasks,
        "complete": complete_task,
        "c": complete_task,
        "exit": None,
        "quit": None,
        "q": None,
        "help": None,
        "h": None,
    }

    print("Personal Task Manager — commands: add (a), list (l), complete (c), exit (q)")
    while True:
        cmd = input("> ").strip().lower()
        if cmd in ("exit", "quit", "q"):
            print("Goodbye.")
            break
        if cmd in ("help", "h"):
            print("Commands: add (a) — add a task; list (l) — show tasks; complete (c) — mark task done; exit (q) — quit")
            continue
        action = actions.get(cmd)
        if action:
            action(tasks)
        else:
            print("Unknown command. Type 'help' for available commands.")

if __name__ == "__main__":
    main()
