#!/usr/bin/env python3
from dataclasses import dataclass, field
from enum import IntEnum
from typing import List
import datetime

class Priority(IntEnum):
    HIGH = 1
    MEDIUM = 2
    LOW = 3

    def label(self) -> str:
        return {Priority.HIGH: "High", Priority.MEDIUM: "Medium", Priority.LOW: "Low"}[self]

@dataclass(order=True)
class Task:
    sort_index: int = field(init=False, repr=False)
    priority: Priority
    name: str
    created_at: datetime.datetime = field(default_factory=datetime.datetime.now)

    def __post_init__(self):
        # Lower sort_index sorts first (High -> Low)
        self.sort_index = int(self.priority)

def prompt_priority() -> Priority:
    while True:
        raw = input("Priority (1=High, 2=Medium, 3=Low): ").strip()
        if raw in ("1", "2", "3"):
            return Priority(int(raw))
        # accept words
        lowered = raw.lower()
        if lowered in ("high", "h", "1"):
            return Priority.HIGH
        if lowered in ("medium", "m", "2"):
            return Priority.MEDIUM
        if lowered in ("low", "l", "3"):
            return Priority.LOW
        print("Invalid priority. Enter 1, 2, 3 or High/Medium/Low.")

def add_task(tasks: List[Task]) -> None:
    name = input("Task name: ").strip()
    if not name:
        print("Task name cannot be empty.")
        return
    pr = prompt_priority()
    tasks.append(Task(priority=pr, name=name))
    print(f"Added: '{name}' [{pr.label()}]")

def list_tasks(tasks: List[Task]) -> None:
    if not tasks:
        print("No tasks.")
        return
    # Sort by priority (1..3) then by creation time
    sorted_tasks = sorted(tasks, key=lambda t: (t.priority, t.created_at))
    print("\nTasks:")
    for i, t in enumerate(sorted_tasks, start=1):
        ts = t.created_at.strftime("%Y-%m-%d %H:%M:%S")
        print(f"{i}. [{t.priority.label()}] {t.name} (added: {ts})")
    print()

def main():
    tasks: List[Task] = []
    actions = {
        "add": add_task,
        "a": add_task,
        "list": list_tasks,
        "l": list_tasks,
        "exit": None,
        "quit": None,
        "q": None,
        "help": None,
        "h": None,
    }

    print("Personal Task Manager — commands: add (a), list (l), exit (q)")
    while True:
        cmd = input("> ").strip().lower()
        if cmd in ("exit", "quit", "q"):
            print("Goodbye.")
            break
        if cmd in ("help", "h"):
            print("Commands: add (a) — add a task; list (l) — show tasks; exit (q) — quit")
            continue
        action = actions.get(cmd)
        if action:
            action(tasks)
        else:
            print("Unknown command. Type 'help' for available commands.")

if __name__ == "__main__":
    main()
